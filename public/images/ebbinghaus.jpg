<svg width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="180" height="180" fill="#E5E5E5"/>
  <rect x="20" y="20" width="140" height="140" fill="#D4D4D4"/>
  
  <!-- Face outline -->
  <circle cx="90" cy="70" r="30" fill="#A3A3A3"/>
  
  <!-- Hair and beard -->
  <path d="M60 70C60 70 70 30 90 30C110 30 120 70 120 70" fill="#8D8D8D"/>
  <path d="M60 70C60 70 70 110 90 110C110 110 120 70 120 70" fill="#8D8D8D"/>
  
  <!-- Glasses -->
